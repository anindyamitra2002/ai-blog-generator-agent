# ==========================================================================
# LLM provider: "ollama" for local execution, or "openai" for any
# OpenAI-compatible endpoint — including Omniroute.
# ==========================================================================
LLM_PROVIDER=openai

# --- Ollama settings (only used if LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- OpenAI-compatible / Omniroute settings ---
OPENAI_API_BASE=http://localhost:20128/v1
OPENAI_API_KEY=your-omniroute-key-here
OPENAI_MODEL=auto

# --- General settings ---
LLM_TEMPERATURE=0.7
PLANNER_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120

# ==========================================================================
# Search APIs
# ==========================================================================
# Tavily — https://tavily.com
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5

# Serper (Google Search API) — https://serper.dev
SERPER_API_KEY=

# ==========================================================================
# Deep-research / recency settings
# ==========================================================================
# How many days back counts as "recent news" for tavily_news / serper_recent / ddg_recent.
NEWS_RECENCY_DAYS=14
BACKGROUND_RECENCY_DAYS=365
DEEP_RESEARCH_MAX_ITERATIONS=3
MAX_QUERIES_PER_ITERATION=5
MAX_PARALLEL_SEARCHES=5

# ==========================================================================
# Image APIs — at least ONE recommended. Priority order is
# Serper/Tavily (web image search) → Unsplash → Pexels → Pixabay.
# ==========================================================================
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
IMAGE_MIN_WIDTH=1200
IMAGE_MIN_HEIGHT=600

# ==========================================================================
# Optional: Arxiv tool for academic / scientific topics
# ==========================================================================
ENABLE_ARXIV=false

# ==========================================================================
# Memory settings (self-hosted Mem0) — DISABLED, kept for reference only.
# main.py no longer imports or calls memory/mem0_store.py: recalling old
# posts was bleeding stale content into new generations. Setting this var
# has no effect unless you deliberately re-wire memory back into main.py.
# ==========================================================================
MEM0_USER_ID=blog-agent

# ==========================================================================
# Grounding / anti-hallucination
# ==========================================================================
# Minimum characters of genuine (non-error) collected search evidence before
# the research graph trusts a brief to be well-grounded. Below this, the
# brief is flagged `evidence_insufficient` and main.py stops before writing
# a post (unless you pass --force-thin).
MIN_EVIDENCE_CHARS=400
